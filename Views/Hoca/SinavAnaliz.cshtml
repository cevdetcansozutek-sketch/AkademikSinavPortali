@model IEnumerable<AkademikSinavPortali.Models.OgrenciYanitlari>
@{
    ViewData["Title"] = "Sınav Analizi";
}

<div class="container mt-4">
    <h2><i class="bi bi-clipboard-data"></i> Sınav Detay Analizi</h2>

    @if (ViewBag.OgrenciAdSoyad != null)
    {
        <div class="alert alert-secondary fs-5 shadow-sm">
            <strong>Öğrenci:</strong> @ViewBag.OgrenciAdSoyad <br />
            <strong>Sınav:</strong> @ViewBag.SinavAdi
        </div>
    }

    <hr />

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-bordered shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 5%">#</th>
                        <th style="width: 55%">Soru Metni</th>
                        <th class="text-center" style="width: 20%">Öğrencinin Cevabı</th>
                        <th class="text-center" style="width: 20%">Doğru Cevap</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int sira = 1;
                    }
                    @foreach (var yanit in Model)
                    {
                        // HOCANIN İSTEDİĞİ: Conditional Styling (Koşullu Renklendirme)
                        string satirSinifi = ""; // Başlangıçta boş

                        if (yanit.VerilenCevap == yanit.Soru.DogruCevap)
                        {
                            satirSinifi = "table-success"; // Doğruysa yeşil satır
                        }
                        else
                        {
                            satirSinifi = "table-danger"; // Yanlışsa kırmızı satır
                        }

                        <tr class="@satirSinifi">
                            <td class="fw-bold">@sira</td>
                            <td>@yanit.Soru.SoruMetni</td>
                            <td class="text-center fw-bold fs-5">
                                @(string.IsNullOrEmpty(yanit.VerilenCevap) ? "BOŞ" : yanit.VerilenCevap)
                            </td>
                            <td class="text-center fw-bold fs-5">@yanit.Soru.DogruCevap</td>
                        </tr>
                        sira++;
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-warning">@ViewBag.Mesaj</div>
    }

    <a asp-action="OgrenciArama" class="btn btn-dark mt-3">Öğrenci Aramaya Dön</a>
</div>